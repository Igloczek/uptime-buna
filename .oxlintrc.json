{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "ignorePatterns": ["test/*.js", "src/server/modules/**", "src/util.js"],
    "plugins": ["typescript", "oxc"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "curly": "error",
        "eqeqeq": "warn",
        "no-constant-condition": [
            "error",
            {
                "checkLoops": false
            }
        ],
        "no-control-regex": "off",
        "no-empty": [
            "error",
            {
                "allowEmptyCatch": true
            }
        ],
        "no-throw-literal": "off",
        "no-unused-expressions": "off",
        "no-unused-vars": "warn",
        "no-var": "error",
        "typescript/no-this-alias": "off"
    },
    "env": {
        "browser": true,
        "commonjs": true,
        "es2020": true,
        "node": true,
        "builtin": true
    }
}
