{
    "name": "uptime-buna",
    "version": "2.4.0",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/igloczek/uptime-buna.git"
    },
    "engines": {
        "bun": ">= 1.2.0"
    },
    "scripts": {
        "dev": "concurrently -k -r \"wait-on tcp:3000 && bun run dev:server\" \"bun run dev:frontend\"",
        "dev:frontend": "NODE_ENV=development vite --host --config ./config/vite.config.ts",
        "dev:frontend:container": "NODE_ENV=development DEVCONTAINER=1 vite --host --config ./config/vite.config.ts",
        "dev:server": "NODE_ENV=development bun src/server/server.ts",
        "dev:server:watch": "NODE_ENV=development bun --watch src/server/server.ts",
        "start": "bun src/server/server.ts",
        "build": "bun --bun vite build --config ./config/vite.config.ts",
        "build-docker": "bun run build && docker build -f Dockerfile -t uptime-buna:local .",
        "preview": "vite preview --host --config ./config/vite.config.ts",
        "lint": "bun run lint:js && bun run lint:style",
        "lint:fix": "bun run lint:js:fix && bun run lint:style:fix",
        "lint:js": "oxlint --config ./.oxlintrc.json --ignore-path .gitignore .",
        "lint:js:fix": "oxlint --config ./.oxlintrc.json --ignore-path .gitignore --fix .",
        "lint:style": "stylelint \"**/*.{vue,css,scss}\" --ignore-path .gitignore",
        "lint:style:fix": "stylelint \"**/*.{vue,css,scss}\" --fix --ignore-path .gitignore",
        "fmt": "oxfmt \"**/*.{js,ts,vue,css,scss,json,md,yml,yaml}\"",
        "tsc": "tsc --project ./tsconfig-backend.json",
        "test": "bun run test:backend && bun run test-e2e",
        "test-with-build": "bun run build && bun run test:backend",
        "test:backend": "bun test test/backend-test",
        "test-e2e": "playwright test --config ./config/playwright.config.ts",
        "test-e2e-ui": "playwright test --config ./config/playwright.config.ts --ui --ui-port=51063",
        "playwright-codegen": "playwright codegen localhost:3000 --save-storage=./private/e2e-auth.json",
        "playwright-show-report": "playwright show-report ./private/playwright-report",
        "reset-password": "bun scripts/admin/reset-password.js",
        "remove-2fa": "bun scripts/admin/remove-2fa.js",
        "reset-migrate-aggregate-table-state": "bun scripts/admin/reset-migrate-aggregate-table-state.js",
        "simple-dns-server": "bun scripts/dev/simple-dns-server.js",
        "simple-mqtt-server": "bun scripts/dev/simple-mqtt-server.js",
        "simple-mongo": "docker run --rm -p 27017:27017 mongo",
        "simple-postgres": "docker run --rm -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres"
    },
