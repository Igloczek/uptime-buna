#!/bin/sh
# Pre-commit hook: format staged files with oxfmt before commit.
#
# Prerequisites:
# - `bun install` so node_modules/.bin/oxfmt is present
# - Bun (discovered automatically; override with BUN_BIN if needed)
# - perl (for null-delimited staged-file filtering)
#
# Limitations:
# - Formats entire files, then re-stages them with `git add`. Partial staging
#   (git add -p) is not preserved: unstaged hunks are folded into the index.
# - Ignore-path rules mirror .oxfmtrc.json ignorePatterns; keep them in sync.
set -eu

root=$(git rev-parse --show-toplevel)
cd "$root"

oxfmt_cli="$root/node_modules/.bin/oxfmt"
if [ ! -f "$oxfmt_cli" ]; then
    echo "Error: oxfmt not found. Run 'bun install' in the repository root." >&2
    exit 1
fi

find_bun() {
    if [ -n "${BUN_BIN:-}" ] && [ -x "$BUN_BIN" ]; then
        echo "$BUN_BIN"
        return 0
    fi

    for candidate in \
        /usr/local/bin/bun \
        /opt/homebrew/bin/bun; do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    if [ -n "${HOME:-}" ]; then
        candidate="$HOME/.bun/bin/bun"
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    fi

    search_path="/usr/local/bin:/opt/homebrew/bin"
    if [ -n "${HOME:-}" ]; then
        search_path="$HOME/.bun/bin:$search_path"
    fi
    if [ -n "${PATH:-}" ]; then
        search_path="$search_path:$PATH"
    fi

    bun_path=$(PATH="$search_path" command -v bun 2>/dev/null || true)
    if [ -n "$bun_path" ] && [ -x "$bun_path" ]; then
        echo "$bun_path"
        return 0
    fi

    return 1
}

bun=$(find_bun) || {
    echo "Error: bun not found. Install Bun (https://bun.sh) or set BUN_BIN to the bun executable." >&2
    exit 1
}

list_file=$(mktemp)
trap 'rm -f "$list_file"' EXIT INT TERM

# Ignore rules must stay aligned with ignorePatterns in .oxfmtrc.json.
git diff --cached --name-only -z --diff-filter=ACMR | perl -0ne '
    for my $file (split(/\0/, $_, -1)) {
        next if $file eq "";
        next unless $file =~ /\.(js|ts|vue|css|scss|json|md|yml|yaml)$/i;
        next if $file =~ m{(?:^|/)(?:node_modules|dist|dist-ssr|private|out|tmp)(?:/|$)};
        next if $file =~ m{(?:^|/)data[^/]*(?:/|$)};
        print "$file\0";
    }
' > "$list_file"

if [ ! -s "$list_file" ]; then
    exit 0
fi

xargs -0 "$bun" "$oxfmt_cli" --write < "$list_file"
xargs -0 git add -- < "$list_file"